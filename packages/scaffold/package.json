{
  "name": "@vo-coder/scaffold",
  "version": "0.1.0",
  "description": "Markdown-driven project scaffolding — PROJECT_SETUP.md questionnaire generates a per-project PROJECT_CONFIG.md",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vo-scaffold": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@vo-coder/project-config": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "~5.9.0",
    "vitest": "^4.0.0"
  }
}
